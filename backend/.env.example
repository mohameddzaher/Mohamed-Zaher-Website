# ========= Server =========
NODE_ENV=development
# Port 5000 is taken by macOS AirPlay Receiver on recent macOS versions — default to 5001
PORT=5001
CLIENT_URL=http://localhost:3000

# ========= MongoDB =========
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# ========= JWT =========
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-different-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ========= Cookies =========
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ========= Cloudinary =========
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ========= Email (Gmail SMTP for MVP) =========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Mohamed Zaher <noreply@example.com>"
EMAIL_TO_ADMIN=mohamedzaher.dev@gmail.com

# ========= Seed admin (created on first `npm run seed`) =========
# IMPORTANT: wrap any password containing "#" in double quotes (dotenv treats # as a comment)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD="change-me-strong-password"
SEED_ADMIN_NAME=Admin
